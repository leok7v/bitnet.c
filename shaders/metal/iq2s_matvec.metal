kernel void iq2s_matvec(device const uchar *weights [[buffer(0)]],
                        device const float *x       [[buffer(1)]],
                        device float       *out     [[buffer(2)]],
                        constant uint      *p       [[buffer(3)]],
                        uint3 wid [[threadgroup_position_in_grid]],
                        uint3 lid [[thread_position_in_threadgroup]]) {
    uint rows = p[0], cols = p[1], extra = p[3];
    uint out_offset = p[5];
    uint tile_start = (extra > 0) ? (wid.x + wid.y * extra) * TILE_ROWS : wid.x * TILE_ROWS;
    uint token = (extra > 0) ? 0 : wid.y;
    uint tid = lid.x;
    uint local_row = tid / THREADS_PER_ROW;
    uint local_elem = tid % THREADS_PER_ROW;
    uint global_row = tile_start + local_row;
    uint n_blocks = cols / QK_K;
    uint x_base = token * cols;

    float acc = 0.0f;
    if (global_row < rows) {
        uint row_byte = global_row * n_blocks * BLOCK_BYTES;
        for (uint bi = 0; bi < n_blocks; bi++) {
            device const uchar *block  = weights + row_byte + bi * BLOCK_BYTES;
            float d = float(*(device const half *)block);
            device const uchar *qs     = block + 2;
            device const uchar *qh     = block + 66;
            device const uchar *scales = block + 74;

            uint ib32 = local_elem;
            uint sc = scales[ib32];
            float db0 = d * (0.5f + float(sc & 0xFu)) * 0.25f;
            float db1 = d * (0.5f + float(sc >> 4))  * 0.25f;
            uint qh_byte = qh[ib32];

            uint sub_x_base = x_base + bi * QK_K + ib32 * 32;
            float sub = 0.0f;
            for (uint l = 0; l < 4; l++) {
                float dl = (l < 2) ? db0 : db1;
                uint idx10 = (uint)qs[4 * ib32 + l]
                           | ((qh_byte << (8 - 2 * l)) & 0x300u);
                uint grid_off = idx10 * 8;
                uint signs = qs[32 + 4 * ib32 + l];
                for (uint j = 0; j < 8; j++) {
                    float w = float(iq2s_grid[grid_off + j]);
                    if ((signs >> j) & 1u) w = -w;
                    sub += dl * w * x[sub_x_base + l * 8 + j];
                }
            }
            acc += sub;
        }
    }

    float val = acc;
    val += simd_shuffle_xor(val, 4);
    val += simd_shuffle_xor(val, 2);
    val += simd_shuffle_xor(val, 1);

    if (local_elem == 0 && global_row < rows)
        out[out_offset + token * rows + global_row] = val;
}
